# -----------------------------------------------------------------------------
# ShortsAuto - 현재 데모 및 AI 생성 엔드포인트
# 실제 비밀값을 이 파일에 넣거나 Git에 커밋하지 마세요.
# -----------------------------------------------------------------------------

# 기본값 true. 외부 시스템에 부작용이 없는 샘플 데이터/응답을 사용합니다.
SHORTSAUTO_DEMO_MODE=true

# AI Gateway는 선택 사항입니다. 둘 중 하나만 사용하세요.
# 정적 키: 로컬, CI, Vercel 외부 런타임에 적합합니다.
AI_GATEWAY_API_KEY=
# OIDC: `vercel env pull .env.local`이 발급합니다. 수동으로 커밋하지 마세요.
VERCEL_OIDC_TOKEN=
# 반드시 현재 Gateway가 지원하는 provider/model ID를 사용하세요.
AI_MODEL=openai/gpt-5.4

# -----------------------------------------------------------------------------
# 운영 연동 준비 항목 - 현재 데모에서는 사용하지 않습니다.
# -----------------------------------------------------------------------------

# Google OAuth / YouTube Data API v3
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/auth/youtube/callback
# 운영에서도 최초 업로드 기본값은 private로 유지하세요.
YOUTUBE_UPLOAD_DEFAULT_PRIVACY=private

# OAuth refresh token 암호화를 위한 32-byte 이상의 무작위 키.
# 실제 운영에서는 KMS/secret manager를 우선 사용하세요.
TOKEN_ENCRYPTION_KEY=

# PostgreSQL
DATABASE_URL=

# S3-compatible private Object Storage
STORAGE_ENDPOINT=
STORAGE_BUCKET=shortsauto
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# 제어면과 외부 media worker 사이의 요청 서명용 비밀값.
# 환경별로 서로 다른 32-byte 이상의 무작위 값을 사용하세요.
WORKER_SHARED_SECRET=
